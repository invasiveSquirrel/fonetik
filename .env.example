# Copy this file to .env.local and add your actual API key
# DO NOT commit .env.local to version control

# Google Generative AI API Key (get from https://aistudio.google.com/app/apikeys)
GOOGLE_API_KEY=your_api_key_here

# Google Cloud credentials path (optional, defaults to ~/panglossia/google-credentials.json)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json
